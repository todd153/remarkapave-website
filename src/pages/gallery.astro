---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CtaBand from '../components/CtaBand.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import { breadcrumbSchema } from '../utils/schema.js';

const trail = [
  { name: 'Home', href: '/' },
  { name: 'Gallery', href: '/gallery/' },
];
const title = 'Before & After Gallery | RemarkaPave Pavement Work OK';
const description =
  'Before & after photos of RemarkaPave line striping, sealcoating, and pressure washing across Ponca City and the Tulsa metro, Oklahoma.';

---

<style>
  .video-wrapper {
    position: relative;
    width: 100%;
    max-width: 800px;
    aspect-ratio: 16 / 9;
    margin-left: auto;
    margin-right: auto;
  }
  .video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>

<Base {title} {description} schema={[breadcrumbSchema(trail)]}>
  <Breadcrumbs {trail} />
  <section class="section" style="padding-top:34px;">
    <div class="container">
      <span class="kicker">The Work</span>
      <h1>Before &amp; after</h1>
      <p class="lede" style="margin-top:16px;">
        The lot does the talking. These are the kinds of transformations a RemarkaPave visit
        delivers — real project photos from our jobs are being added as we build the gallery
        out, tagged by town.
      </p>

      <div class="video-wrapper" style="margin-top:30px;">
        <iframe
          src="https://www.youtube.com/embed/QlLBBzfArWY"
          title="RemarkaPave pavement work"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>

      <h2 style="margin-top:30px;">See the difference</h2>
      <p class="note" style="margin:6px 0 14px;">Drag the slider to reveal the transformation.</p>
      <div style="max-width:820px;">
        <BeforeAfter
          before="/images/gallery/osu-before.jpg"
          after="/images/gallery/osu-after.jpg"
          beforeAlt="Blank new-poured concrete parking lot before striping at Oklahoma State University, Stillwater"
          afterAlt="Freshly painted parking-stall layout on new concrete at Oklahoma State University, Stillwater"
          caption="OSU, Stillwater — a brand-new parking layout striped on fresh concrete. Drag to compare."
        />
      </div>

      <p class="note" style="margin-top:20px;">
        Want to see work near you before booking? Ask — we'll point you to lots we've done in
        your area.
      </p>
    </div>
  </section>
  <CtaBand heading="Want your lot in this gallery?" />
</Base>
