---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FaqBlock from '../components/FaqBlock.astro';
import CtaBand from '../components/CtaBand.astro';
import { site } from '../data/site.js';
import { faqSchema, breadcrumbSchema } from '../utils/schema.js';

const title = 'Pavement FAQs - Pricing, Timing & Process | RemarkaPave';
const description = 'Real answers to common questions about parking lot striping, sealcoating, crack filling, and pressure washing in Oklahoma - including ballpark pricing.';

const trail = [
  { name: 'Home', href: '/' },
  { name: 'FAQ', href: '/faq/' },
];

const pricingFaqs = [
  {
    q: 'How much does parking lot striping cost in Oklahoma?',
    a: "Most commercial re-stripes run $500-$2,000 depending on stall count, layout complexity, and condition of the old lines. ADA upgrades - correct symbols, van-accessible spacing, access aisles - add $200-$800 on top of the re-stripe, depending on how many stalls need work. New layouts from scratch start around $1,000. Every job gets a free written quote with stall counts, materials, and labor broken out before we start.",
  },
  {
    q: 'How much does sealcoating cost for a parking lot?',
    a: "Commercial sealcoating runs roughly $0.15-$0.30 per square foot, depending on lot condition and how many coats are needed. A 10,000 sq ft lot typically runs $1,500-$3,000. Heavily oxidized pavement that hasn't been sealed in 5+ years often needs two coats - the first soaks into the dry asphalt, the second does the protecting. Compare that to repaving at $8-$15/sq ft and the math on regular maintenance is obvious. Every job is quoted in writing by square footage.",
  },
  {
    q: 'What does crack filling cost?',
    a: "Crack filling runs $1.50-$4.00 per linear foot depending on crack width and whether routing is needed first. A typical commercial lot with moderate cracking runs $300-$1,200. It's consistently the highest-ROI repair in pavement maintenance - far cheaper than pothole repair or base work after water damage has set in.",
  },
  {
    q: 'How much does commercial pressure washing cost?',
    a: 'Lot washing runs $0.10-$0.20 per square foot - a 10,000 sq ft lot typically runs $800-$2,000. Oil stain pre-treatment is priced separately, usually $30-$75 per stall depending on stain age and severity. Bundling a wash with striping or sealcoating in the same visit often reduces the total cost of both.',
  },
  {
    q: 'What is the minimum job size?',
    a: 'RemarkaPave has a $600 job minimum. Smaller jobs are welcome when bundled - for example, a quick crack fill, oil stain treatment, and ADA stencil re-do can often combine into a single efficient visit that clears the minimum.',
  },
];

const processFaqs = [
  {
    q: 'Do you do residential driveways?',
    a: 'No - RemarkaPave focuses on commercial properties: parking lots, storefronts, drive-thrus, and multi-unit properties. Commercial pavement has different standards, materials, and liability than residential work, and we want to stay sharp where we are best.',
  },
  {
    q: 'How quickly can you get out for an estimate?',
    a: 'Most written quotes come back within one business day. For a lot we can view via satellite imagery, we can often quote faster. Complex jobs - new layouts, large lots, or multi-service packages - may take an extra day to price properly.',
  },
  {
    q: 'Do I have to be there for the estimate?',
    a: 'No. Many estimates are done via satellite imagery and a lot walk without the owner present. We send the written quote by email and follow up by phone.',
  },
  {
    q: 'Can you work around my business hours so my lot does not have to close?',
    a: 'Yes - early mornings, evenings, and phased striping (one section at a time) are all options. Sealcoating typically needs the lot closed for 4-6 hours for curing, but we schedule it around your slowest period.',
  },
  {
    q: 'How long does striping take to dry?',
    a: 'PROMAR solvent-based acrylic paint is touch-dry in 20-30 minutes under normal Oklahoma conditions. We will give you the all-clear time in the quote based on the weather forecast for your job day.',
  },
  {
    q: 'Do you provide written contracts?',
    a: 'Yes. Every job gets a written materials-and-labor quote before work starts. You approve it, we do the work. No surprise add-ons.',
  },
];

const comparisonFaqs = [
  {
    q: "Sealcoating vs. repaving - how do I know which one I need?",
    a: "Sealcoating is a surface treatment - it protects asphalt that's still structurally sound. If your lot has surface cracks and oxidation (gray, dry-looking asphalt) but the base is solid, sealcoating and crack filling will extend that pavement another 5-10 years for a fraction of repaving cost. Repaving makes sense when the base has failed - signs are deep alligator cracking, potholes that come back after repair, or sections that sink or shift. We will tell you honestly which situation you're in during a free lot assessment.",
  },
  {
    q: 'Crack filling vs. doing nothing - what actually happens if I wait?',
    a: "Oklahoma's freeze-thaw cycle is the real problem. Water gets into a crack, freezes, expands, and widens the crack. One winter can turn a hairline crack into a half-inch gap. Two winters turns gaps into potholes. Pothole repair costs 5-10x more per linear foot than crack filling. The asphalt base beneath the pothole can fail, requiring excavation and repaving at $8-$15/sq ft. The best time to fill a crack is when it first appears. The second best time is now.",
  },
  {
    q: 'Hot-water pressure washing vs. cold-water - is there a real difference?',
    a: "Yes, especially for oil and grease. Cold water can dilute and move surface grime but can't break down hydrocarbon bonds - so oil stains get lighter but don't come out. Hot water breaks down oil at the molecular level, which is why a hot-water rig with the right dwell time actually lifts stains. If your lot has a drive-thru lane or active vehicle fluid stains, cold water washing is mostly cosmetic.",
  },
  {
    q: 'Professional striping vs. doing it ourselves - is the difference worth it?',
    a: 'Depends what you want from the result. DIY walk-behind machines use water-based paint that fades in one Oklahoma summer and often lays uneven lines due to manual speed variation. A commercial striper uses solvent-based paint, a self-propelled machine with consistent speed, and proper stall-width templates - lines that last 2-3 years and look intentional. If your lot is customer-facing, the professional result is usually worth it. If it is a back-of-house employee lot with minimal ADA requirements, DIY might be fine for a season.',
  },
  {
    q: 'Strip before sealcoating, or sealcoat first?',
    a: 'Sealcoat first, stripe second - always. Fresh sealer gives you a clean black surface that makes striping lines pop and adhere better. Striping before sealing means sealing over your paint lines and losing most of them. If your lot needs both, they are typically done in the same week: sealcoat Monday, stripe Thursday after the sealer cures.',
  },
];

const adaFaqs = [
  {
    q: 'How many ADA-accessible parking stalls does my lot legally need?',
    a: 'The ADA requires 1 accessible stall per 25 total stalls up to 100 stalls, then a sliding scale for larger lots. At least one of those stalls must be van-accessible (96 inches wide with an 8-foot access aisle). We check your stall count and layout during any estimate - at no charge - because getting this wrong creates liability exposure for the property owner, not the line painter.',
  },
  {
    q: "What happens if my lot isn't ADA compliant?",
    a: 'ADA complaints are filed against the property owner or business operator, not the painting contractor. Settlement costs for ADA access lawsuits typically run $10,000-$50,000+ including legal fees. Correct striping - stall count, van-accessible space, proper access aisles, and current symbol stencils - is the cheapest compliance step a property can take.',
  },
  {
    q: 'What makes a parking lot ADA compliant?',
    a: 'The main requirements: correct number of accessible stalls for your total stall count, at least one van-accessible stall (wider, with a larger access aisle), stalls as close as possible to the accessible entrance, correct ISA (wheelchair) symbol stenciling, and an unobstructed access route from the stall to the building entrance. Fire lane and no-parking zone markings are separate from ADA but often updated at the same time.',
  },
];

const allFaqs = [...pricingFaqs, ...processFaqs, ...comparisonFaqs, ...adaFaqs];
---

<Base {title} {description} schema={[faqSchema(allFaqs), breadcrumbSchema(trail)]}>
  <Breadcrumbs {trail} />

  <section class="section" style="padding-top:34px;">
    <div class="container" style="max-width:820px;">
      <h1>Frequently Asked Questions</h1>
      <p style="font-size:1.1rem; color:var(--body); margin-bottom:2rem;">
        Real answers about pricing, timing, and process - no runaround.
        Can't find what you need? Call us directly at <a href={site.phoneHref}>{site.phone}</a>.
      </p>

      <h2 style="margin-top:2rem;">Pricing</h2>
      <FaqBlock faqs={pricingFaqs} />

      <h2 style="margin-top:2.5rem;">Process & scheduling</h2>
      <FaqBlock faqs={processFaqs} />

      <h2 style="margin-top:2.5rem;">Comparisons - striping vs. repaving, hot vs. cold, and more</h2>
      <FaqBlock faqs={comparisonFaqs} />

      <h2 style="margin-top:2.5rem;">ADA compliance</h2>
      <FaqBlock faqs={adaFaqs} />
    </div>
  </section>

  <CtaBand />
</Base>
