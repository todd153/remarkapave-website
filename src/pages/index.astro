---
import Base from '../layouts/Base.astro';
import QuoteForm from '../components/QuoteForm.astro';
import FaqBlock from '../components/FaqBlock.astro';
import CtaBand from '../components/CtaBand.astro';
import Testimonials from '../components/Testimonials.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import ServiceAreaMap from '../components/ServiceAreaMap.astro';
import { site, trustSignals, serviceAreas } from '../data/site.js';
import { services, coreServices, priceDisclaimer } from '../data/services.js';
import { towns } from '../data/towns.js';
import { faqSchema } from '../utils/schema.js';

const homeFaqs = [
  { q: 'How much does parking lot striping cost in Oklahoma?', a: 'RemarkaPave prices striping per stall, with new layouts, ADA stalls, and stencils itemized in a free written quote — most come back within one business day. Job minimums apply.' },
  { q: 'What areas does RemarkaPave serve?', a: 'We’re based in Ponca City and serve Kay County (Newkirk, Tonkawa, Blackwell), the Tulsa metro (Tulsa, Broken Arrow, Owasso, Bixby, Jenks, Sand Springs, Claremore), and Bartlesville, Oklahoma.' },
  { q: 'How often should I sealcoat my lot in Oklahoma?', a: 'Every 2–3 years. Oklahoma sun and freeze-thaw cycles dry asphalt out; regular sealcoating costs pennies per square foot compared to repaving.' },
  { q: 'Is RemarkaPave licensed and insured?', a: 'Yes — RemarkaPave LLC is licensed and insured, gives free estimates, and provides a written materials-and-labor breakdown on every job.' },
  { q: 'What is a RemarkaReport™?', a: 'Our branded pavement assessment: a documented lot walk with photos, plain-English condition grades, and a prioritized 1–3 year maintenance plan. Free with any estimate.' },
];

const title = 'Parking Lot Striping Ponca City & Tulsa, OK | RemarkaPave';
const description =
  'Commercial line striping, sealcoating, crack filling & pressure washing in Ponca City, the Tulsa metro & Bartlesville. Licensed & insured. Free quotes.';
---

<Base {title} {description} schema={[faqSchema(homeFaqs)]} ogImage="/images/integris-ponca-city-fire-lane-crosswalk-striping.jpg">
  <link slot="head" rel="preload" as="image" href="/images/integris-ponca-city-fire-lane-crosswalk-striping.jpg" fetchpriority="high" />
  <!-- ============ HERO ============ -->
  <section class="hero-static" id="hero" aria-label="RemarkaPave — Integris Ponca City Hospital fire lane restriping">
    <img
      class="hero-bg" width="1600" height="900"
      src="/images/integris-ponca-city-fire-lane-crosswalk-striping.jpg"
      alt="Freshly painted crosswalk and red fire lane curb at the Integris Ponca City Hospital main entrance"
      fetchpriority="high"
    />
    <div class="shade"></div>
    <div class="hero-overlay">
      <h1>Your lot is your first impression.</h1>
      <p class="sub">We make it remarkable.</p>
      <div class="hero-ctas">
        <a class="btn btn-quote" href="/free-quote/">Get a Free Quote</a>
        <a class="btn btn-ghost-dark" href={site.phoneHref} data-track="call">Call {site.phone}</a>
      </div>
    </div>
  </section>

  <!-- ============ TRUST BAR ============ -->
  <div class="trustbar" role="complementary" aria-label="Credentials">
    <ul>
      {trustSignals.map((t) => <li>{t}</li>)}
    </ul>
  </div>

  <!-- ============ DIRECT ANSWER (AEO) ============ -->
  <section class="section">
    <div class="container">
      <p class="lede">
        <strong>{site.name}</strong> is a commercial pavement maintenance contractor based in
        Ponca City, Oklahoma, serving Kay County, the Tulsa metro, and Bartlesville. We stripe,
        sealcoat, crack-fill, and pressure wash parking lots for property managers, retail
        centers, HOAs, and business owners — with free estimates and a written
        materials-and-labor breakdown on every job. Call <a href={site.phoneHref} data-track="call">{site.phone}</a>.
      </p>
    </div>
  </section>

  <!-- ============ SERVICES ============ -->
  <section class="section alt" id="services">
    <div class="container">
      <span class="kicker">What We Do</span>
      <h2>One crew. One written quote.<br />A finished lot.</h2>
      <div class="grid grid-3" style="margin-top:30px;">
        {services.map((s) => (
          <article class="card">
            <h3><a href={`/services/${s.slug}/`}>{s.name}</a></h3>
            <p style="margin-top:8px; font-size:0.95rem;">{s.blurb}</p>
            <span class="price">{s.priceFrom}</span>
          </article>
        ))}
      </div>
      <p class="note" style="margin-top:18px;">{priceDisclaimer}</p>
    </div>
  </section>

  <!-- ============ REMARKAREPORT BAND ============ -->
  <section class="section">
    <div class="container grid grid-2" style="align-items:center;">
      <div>
        <span class="kicker">Start Smart</span>
        <h2>The RemarkaReport™</h2>
        <p class="lede" style="margin-top:14px;">
          Before you spend a dollar on your lot, know exactly where it stands. We walk the
          property, photograph every problem area, grade the condition in plain English, and
          hand you a prioritized 1–3 year maintenance plan — so you budget instead of react.
        </p>
        <p style="margin-top:16px;"><strong>Free with any estimate.</strong></p>
        <div style="margin-top:20px; display:flex; gap:14px; flex-wrap:wrap;">
          <a class="btn btn-primary" href="/services/remarkareport/">How it works</a>
          <a class="btn btn-outline" href="/free-quote/">Book my RemarkaReport</a>
        </div>
      </div>
      <div class="card" style="border-left:5px solid var(--yellow);">
        <h3>Every RemarkaReport™ includes</h3>
        <ul style="margin:14px 0 0 18px; line-height:2;">
          <li>Full lot walk &amp; photo documentation</li>
          <li>Stall count + ADA compliance check</li>
          <li>Crack, pothole &amp; drainage inventory</li>
          <li>Plain-English condition grades</li>
          <li>Prioritized maintenance budget plan</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ GALLERY TEASER ============ -->
  <section class="section alt">
    <div class="container">
      <span class="kicker">The Work</span>
      <h2>Before &amp; after is our best salesman</h2>
      <p class="lede" style="margin:14px 0 22px;">Drag the slider — bare pavement to a finished, striped layout.</p>
      <div style="max-width:760px; margin:0 auto 30px;">
        <BeforeAfter
          before="/images/gallery/osu-before.jpg"
          after="/images/gallery/osu-after.jpg"
          beforeAlt="Blank new-poured concrete parking lot before striping at Oklahoma State University, Stillwater"
          afterAlt="Freshly painted parking-stall layout on new concrete at Oklahoma State University, Stillwater"
          caption="OSU, Stillwater — a brand-new parking layout striped on fresh concrete. Drag to compare."
        />
      </div>
      <div style="margin-top:26px;">
        <a class="btn btn-outline" href="/gallery/">See the full gallery</a>
      </div>
    </div>
  </section>

  <Testimonials />

  <!-- ============ SERVICE AREA ============ -->
  <section class="section" id="area">
    <div class="container">
      <span class="kicker">Where We Work</span>
      <h2>Ponca City roots. Green Country reach.</h2>
      <p class="lede" style="margin:14px 0 24px;">
        Home base is Ponca City and Kay County. We also run dedicated routes through the Tulsa
        metro and Bartlesville — click your town for local details.
      </p>
      <div class="area-tags">
        {towns.map((t) => (
          <a href={`/services/parking-lot-striping-${t.slug}/`}>{t.name}</a>
        ))}
      </div>
      <ServiceAreaMap />
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="section alt">
    <div class="container" style="max-width:860px;">
      <FaqBlock faqs={homeFaqs} />
    </div>
  </section>

  <!-- ============ QUOTE ============ -->
  <section class="section" id="quote-form">
    <div class="container grid grid-2" style="align-items:start;">
      <div>
        <span class="kicker">Free Estimate</span>
        <h2>Tell us about your lot</h2>
        <p class="lede" style="margin-top:14px;">
          A rough guess on size is fine. You'll hear back within one business day with a
          written breakdown — materials and labor, no mystery numbers.
        </p>
        <ul style="margin:20px 0 0 18px; line-height:2.1;">
          <li>Free, no-obligation estimates</li>
          <li>Written materials &amp; labor breakdown</li>
          <li>Scheduled around your business hours</li>
        </ul>
      </div>
      <QuoteForm />
    </div>
  </section>

  <CtaBand />
</Base>
