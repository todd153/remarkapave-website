---
// "RemarkaBot" — self-contained, rule-based chat widget. No API key, no
// external calls. Answers common questions and funnels to quote/call.
// Minimize (—) collapses to the launcher; Close (×) hides for the session.
import { site } from '../data/site.js';
---
<button class="rp-chat-launch" id="rp-launch" aria-haspopup="dialog" aria-expanded="false">
  💬 Questions? Chat with us
</button>

<section class="rp-chat" id="rp-chat" role="dialog" aria-label="RemarkaPave chat assistant" aria-modal="false" data-phone={site.phone} data-phone-href={site.phoneHref}>
  <header class="rp-chat-head">
    <div class="title">
      RemarkaBot
      <span class="sub">RemarkaPave's helper — real humans at {site.phone}</span>
    </div>
    <button id="rp-min" aria-label="Minimize chat" title="Minimize">—</button>
    <button id="rp-close" aria-label="Close chat" title="Close">×</button>
  </header>
  <div class="rp-chat-body" id="rp-body" aria-live="polite"></div>
  <form class="rp-chat-input" id="rp-form">
    <input type="text" id="rp-text" placeholder="Type a question…" aria-label="Type your question" autocomplete="off" />
    <button type="submit" aria-label="Send">Send</button>
  </form>
</section>

<script>
  import { QUICK, routeMessage, escapeHtml, buildAnswers } from '../scripts/chatbot.js';

  const launch = document.getElementById('rp-launch');
  const panel = document.getElementById('rp-chat');
  const body = document.getElementById('rp-body');
  const form = document.getElementById('rp-form');
  const text = document.getElementById('rp-text');

  const phone = panel.dataset.phone;
  const phoneHref = panel.dataset.phoneHref;

  const ANSWERS = buildAnswers(phone, phoneHref);

  // The 'call' quick-reply label is the live phone number; everything else
  // uses its static label from the shared QUICK list.
  const quickLabel = (label, key) => (key === 'call' ? `Call ${phone}` : label);

  function add(kind, html) {
    const div = document.createElement('div');
    div.className = `rp-msg ${kind}`;
    div.innerHTML = html;
    body.appendChild(div);
    body.scrollTop = body.scrollHeight;
  }

  function addQuick() {
    const wrap = document.createElement('div');
    wrap.className = 'rp-quick';
    QUICK.forEach(([label, key]) => {
      const btnLabel = quickLabel(label, key);
      const b = document.createElement('button');
      b.type = 'button';
      b.textContent = btnLabel;
      b.addEventListener('click', () => {
        add('user', btnLabel);
        setTimeout(() => add('bot', ANSWERS[key]), 250);
      });
      wrap.appendChild(b);
    });
    body.appendChild(wrap);
  }

  function greet() {
    if (body.childElementCount) return;
    add('bot', `Hey! I'm RemarkaBot 👋 — ask me about pricing, services, or our service area, or grab a free quote.`);
    addQuick();
  }

  function open() {
    panel.classList.add('open');
    launch.style.display = 'none';
    launch.setAttribute('aria-expanded', 'true');
    greet();
    text.focus();
  }
  function minimize() {
    panel.classList.remove('open');
    launch.style.display = 'flex';
    launch.setAttribute('aria-expanded', 'false');
    launch.focus();
  }
  function close() {
    panel.classList.remove('open');
    launch.style.display = 'none';
    sessionStorage.setItem('rpChatClosed', '1');
  }

  if (sessionStorage.getItem('rpChatClosed') === '1') launch.style.display = 'none';

  launch.addEventListener('click', open);
  document.getElementById('rp-min').addEventListener('click', minimize);
  document.getElementById('rp-close').addEventListener('click', close);
  panel.addEventListener('keydown', (e) => { if (e.key === 'Escape') minimize(); });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const q = text.value.trim();
    if (!q) return;
    add('user', escapeHtml(q));
    text.value = '';
    setTimeout(() => add('bot', ANSWERS[routeMessage(q)]), 300);
  });
</script>
