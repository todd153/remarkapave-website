# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real keys.

# Google Maps JavaScript API key — powers the 3-circle service area map
# on the homepage (src/components/ServiceAreaMap.astro).
# Get one at: https://console.cloud.google.com/google/maps-apis/credentials
# Enable the "Maps JavaScript API" and restrict the key to remarkapave.com.
PUBLIC_GOOGLE_MAPS_API_KEY=
